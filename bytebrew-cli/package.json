{
  "name": "bytebrew-cli",
  "version": "0.3.0",
  "description": "ByteBrew CLI - AI-powered terminal client",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bytebrew": "dist/index.js"
  },
  "trustedDependencies": [],
  "scripts": {
    "dev": "npx tsx src/index.tsx",
    "dev:bun": "bun run src/index.tsx",
    "build": "bun build src/index.tsx --outdir dist --target bun --external @noble/ciphers --external tweetnacl",
    "build:compile": "bun build src/index.tsx --compile --outfile dist/bytebrew",
    "install:global": "bun run build && bun run scripts/install-global.ts",
    "start": "bun dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@noble/ciphers": "^2.1.1",
    "@types/qrcode": "^1.5.6",
    "cli-spinners": "^3.4.0",
    "commander": "^14.0.3",
    "diff": "^8.0.3",
    "execa": "^9.6.1",
    "glob": "^11.1.0",
    "ignore": "^7.0.5",
    "ink": "^6.6.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^17.0.1",
    "marked-terminal": "^7.3.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.4",
    "react-devtools-core": "^7.0.1",
    "tweetnacl": "^1.0.3",
    "uuid": "^13.0.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@types/diff": "^8.0.0",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.19.7",
    "@types/react": "^19.2.10",
    "@types/uuid": "^10.0.0",
    "bun-types": "^1.3.8",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "patchedDependencies": {}
}
