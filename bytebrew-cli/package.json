{
  "name": "bytebrew-cli",
  "version": "0.2.0",
  "description": "ByteBrew CLI - AI-powered terminal client",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bytebrew": "dist/index.js"
  },
  "scripts": {
    "dev": "npx tsx src/index.tsx",
    "dev:bun": "bun run src/index.tsx",
    "build": "bun build src/index.tsx --outdir dist --target bun --external @grpc/proto-loader --external @grpc/grpc-js",
    "build:compile": "bun build src/index.tsx --compile --outfile dist/bytebrew",
    "start": "bun dist/index.js",
    "proto:generate": "buf generate",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.10",
    "@types/chokidar": "^1.7.5",
    "chokidar": "^5.0.0",
    "cli-spinners": "^3.4.0",
    "commander": "^14.0.3",
    "diff": "^8.0.3",
    "execa": "^9.6.1",
    "glob": "^11.1.0",
    "ignore": "^7.0.5",
    "ink": "^6.6.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^17.0.1",
    "marked-terminal": "^7.3.0",
    "react": "^19.2.4",
    "react-devtools-core": "^7.0.1",
    "tree-sitter-wasms": "^0.1.13",
    "usearch": "^2.15.0",
    "uuid": "^13.0.0",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-types": "^3.17.5",
    "web-tree-sitter": "0.25",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@types/diff": "^8.0.0",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.19.7",
    "@types/react": "^19.2.10",
    "@types/uuid": "^10.0.0",
    "bun-types": "^1.3.8",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "patchedDependencies": {
    "@protobufjs/inquire@1.1.0": "patches/@protobufjs%2Finquire@1.1.0.patch"
  }
}
