{
  "permissions": {
    "allow": [
      "Bash(go build*)",
      "Bash(go run*)",
      "Bash(go test*)",
      "Bash(go vet*)",
      "Bash(golangci-lint*)",
      "Bash(bun run*)",
      "Bash(bun test*)",
      "Bash(bun install*)",
      "Bash(bun build*)",
      "Bash(npm ci*)",
      "Bash(npm run*)",
      "Bash(npm install*)",
      "Bash(flutter *)",
      "Bash(dart *)",
      "Bash(cd *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git ls-files*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(gh *)",
      "Bash(netstat*)",
      "Bash(taskkill*)",
      "Bash(mkdir*)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git checkout -- *)",
      "Bash(git clean*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'FILE=$(cat | jq -r \".tool_input.file_path // empty\"); if [[ \"$FILE\" == *.go ]]; then cd $(dirname \"$FILE\") && golangci-lint run --fix $(basename \"$FILE\") 2>&1 || true; fi'"
          }
        ]
      }
    ]
  }
}
