{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Grep",
      "Glob",
      "WebSearch",
      "WebFetch",
      "Bash(*)",
      "mcp__dart__*",
      "mcp__marionette__*",
      "mcp__tui-test__*",
      "mcp__playwright__*"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf C:/*)",
      "Bash(del /s /q C:/)",
      "Bash(del /s /q C:/Windows/*)",
      "Bash(del /s /q C:/Program Files/*)",
      "Bash(format *)",
      "Bash(diskpart *)",
      "Bash(reg delete *)",
      "Bash(shutdown *)",
      "Bash(taskkill /f /im explorer*)",
      "Bash(*> C:/Windows/*)",
      "Bash(chmod 777 /*)",
      "Bash(chown root /*)",
      "Bash(git reset --hard *)",
      "Bash(git rebase *)",
      "Bash(git clean *)",
      "Bash(git branch -D *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git remote remove *)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "github"
  ]
}
