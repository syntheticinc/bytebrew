# ByteBrew Engine Configuration
# Copy to .env and edit before running: docker compose up -d

# ============================================================
# LLM Provider (at least one required)
# ============================================================

# Cloud LLM (OpenRouter, OpenAI-compatible)
LLM_PROVIDER=openrouter
LLM_API_KEY=sk-or-your-key-here
LLM_MODEL=qwen/qwen3-coder-next

# Local LLM (uncomment ollama service in docker-compose.yml)
# LLM_PROVIDER=ollama
# OLLAMA_URL=http://ollama:11434
# LLM_MODEL=llama3

# ============================================================
# Auth
# ============================================================
# "local"    — engine auto-generates an Ed25519 keypair on first boot (single-replica only).
# "external" — engine validates JWTs using a pre-provisioned public key.
BYTEBREW_AUTH_MODE=local

# Used when BYTEBREW_AUTH_MODE=local (must be a persistent volume mount)
BYTEBREW_JWT_KEYS_DIR=/var/lib/bytebrew/keys

# Used when BYTEBREW_AUTH_MODE=external (path to hex-encoded Ed25519 public key file)
# BYTEBREW_JWT_PUBLIC_KEY_PATH=/etc/bytebrew/jwt_ed25519.pub

# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_PASSWORD=bytebrew

# ============================================================
# Engine
# ============================================================
ENGINE_PORT=8443

# ============================================================
# Bridge (optional, for mobile connectivity)
# ============================================================
# BRIDGE_ENABLED=true
# BRIDGE_URL=wss://bridge.bytebrew.ai
# BRIDGE_AUTH_TOKEN=your-token
