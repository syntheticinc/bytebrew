# ByteBrew Engine Configuration
# Copy to .env and edit before running: docker compose up -d

# ============================================================
# LLM Provider (at least one required)
# ============================================================

# Cloud LLM (OpenRouter, OpenAI-compatible)
LLM_PROVIDER=openrouter
LLM_API_KEY=sk-or-your-key-here
LLM_MODEL=qwen/qwen3-coder-next

# Local LLM (uncomment ollama service in docker-compose.yml)
# LLM_PROVIDER=ollama
# OLLAMA_URL=http://ollama:11434
# LLM_MODEL=llama3

# ============================================================
# Security
# ============================================================
JWT_SECRET=change-me-to-a-random-32-char-secret
# Create first admin after startup: docker exec <engine> bytebrew-ce admin create --username admin --password <pass>

# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_PASSWORD=bytebrew

# ============================================================
# Engine
# ============================================================
ENGINE_PORT=8443

# ============================================================
# Bridge (optional, for mobile connectivity)
# ============================================================
# BRIDGE_ENABLED=true
# BRIDGE_URL=wss://bridge.bytebrew.ai
# BRIDGE_AUTH_TOKEN=your-token
