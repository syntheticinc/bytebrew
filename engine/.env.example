# ByteBrew Engine — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# LLM providers are configured post-install via the onboarding wizard
# (first-run) or Admin → Models. Engine never reads LLM credentials from
# env or config — that flow was removed because an empty fallback key
# led to opaque provider 401s on the first chat turn.

# Optional: License (for Enterprise Edition)
# LICENSE_PUBLIC_KEY_HEX=your-public-key-hex
