---
import BaseLayout from '../layouts/BaseLayout.astro';
import TerminalBlock from '../components/TerminalBlock.astro';
import HeroDemo from '../components/HeroDemo.tsx';

const CE_FEATURES = [
  'Unlimited agents & spawn',
  'Multi-agent orchestration',
  'MCP servers & declarative tools',
  'Cron, webhooks, background jobs',
  'Task system (manage_tasks)',
  'Knowledge/RAG',
  'Model Registry & recommendations',
  'REST API + SSE + WebSocket',
  'Admin Dashboard (full CRUD)',
  'BYOK (bring your own keys)',
  'API tokens with scopes',
  'Docker / bare metal / Kubernetes',
];

const EE_FEATURES_PREVIEW = [
  'Audit Log',
  'Rate Limiting',
  'Prometheus Metrics',
  'Session Explorer',
  'Cost Analytics',
  'Quality Metrics',
  'PII Redaction',
];

const CUSTOM_FEATURES = [
  'SSO / OIDC',
  'Role-based access control (RBAC)',
  'Multi-workspace',
  'Dedicated support (4h SLA)',
  'Custom SLA',
  'Migration assistance',
];

const CAPABILITIES = [
  {
    title: 'Multiple agents, one goal',
    description: 'Supervisor delegates to specialists — research, writing, QA — all coordinated automatically.',
  },
  {
    title: 'Connect any tool or API',
    description: '20+ built-in tools plus any external service via MCP or YAML declarations.',
  },
  {
    title: 'Agents that work while you sleep',
    description: 'Cron schedules and webhook triggers for automated lead scoring, reports, monitoring.',
  },
  {
    title: 'Your docs become agent memory',
    description: 'Upload PDFs or markdown. Agents search via vector similarity with per-agent isolation.',
  },
  {
    title: 'Plug into any app in minutes',
    description: 'Standard REST API with real-time SSE streaming. No SDK required.',
  },
  {
    title: 'Embeddable Widget',
    description: 'Add AI chat to any website with a single <script> tag. Shadow DOM isolated, 6KB gzipped, zero dependencies.',
  },
  {
    title: 'Built-in Web Client',
    description: 'Open /chat/ to test and use your agents instantly. No frontend code needed.',
  },
  {
    title: 'Your data never leaves your servers',
    description: 'Self-hosted with BYOK, API key scopes, and audit logging.',
  },
];

const APPROACH_COMPARISON = [
  { approach: 'Cloud AI platforms', problem: 'Per-token pricing, data leaves your servers, locked to one provider', bytebrew: 'Self-hosted with your own API keys. Pay only your LLM provider directly — no markup' },
  { approach: 'Agent SDKs / frameworks', problem: 'You get a library, not a product. No API server, no admin UI, no scheduling', bytebrew: 'Complete runtime with REST API, admin dashboard, cron triggers, and session management' },
  { approach: 'Visual AI builders', problem: 'Simple chatbots only. No autonomous reasoning, no tool calling, no sub-agents', bytebrew: 'Multi-step reasoning agents that delegate tasks, call tools, and work autonomously' },
  { approach: 'Single-model APIs', problem: 'One provider, no orchestration, no memory, no background jobs', bytebrew: 'Mix any models across agents. Built-in RAG, sessions, and background automation' },
  { approach: 'Custom in-house solutions', problem: '3-6 months to build, ongoing maintenance, team distracted from core product', bytebrew: 'Production-ready in 5 minutes. We maintain the engine — you focus on your product' },
];

const USE_CASES = [
  {
    title: 'AI Support Assistant',
    description: "User asks 'why was I charged twice?' Agent checks your billing API, finds the duplicate charge, initiates a refund, and replies with confirmation — no human touched this ticket. Connect your docs via RAG, add your APIs as tools, deploy.",
    outcome: 'Automate customer interactions at scale',
    iconPath: 'M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155',
  },
  {
    title: 'Operations Autopilot',
    description: 'Incident triage, log analysis, automated remediation — agents monitor and act around the clock.',
    outcome: 'Autonomous operations, not reactive scripts',
    iconPath: 'M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99',
  },
  {
    title: 'Research & Analysis Agents',
    description: 'Multi-step lead research, competitor analysis, report generation. Each step adapts dynamically.',
    outcome: 'AI reasoning replaces rigid pipelines',
    iconPath: 'M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z',
  },
  {
    title: 'Knowledge-Powered Assistants',
    description: 'Upload docs and policies. Agents answer with accurate, sourced responses.',
    outcome: 'Your knowledge, amplified by AI',
    iconPath: 'M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5',
  },
];

const PRODUCTION_ITEMS = [
  {
    title: 'Session persistence',
    description: 'PostgreSQL-backed. Crash mid-conversation? Resumes from last checkpoint.',
  },
  {
    title: 'Structured logging',
    description: 'Every step, tool call, and LLM request logged with trace IDs.',
  },
  {
    title: 'Production deployment guide',
    description: 'Caddy reverse proxy, systemd, SSL/TLS — full ops runbook included.',
    link: '/docs/deployment/production/',
  },
  {
    title: 'Prometheus metrics (EE)',
    description: 'Request latency, token usage, error rates. Alert before users notice.',
  },
];
---

<BaseLayout
  title="ByteBrew Engine — Self-hosted AI Agent Runtime"
  description="Add an AI agent to your product in one day. Self-hosted, any LLM, free forever."
>

  <!-- ================================================================ -->
  <!-- 1. Hero                                                           -->
  <!-- ================================================================ -->
  <section class="pt-12 pb-16 px-4 bg-surface">
    <div class="max-w-5xl mx-auto text-center mb-8">
      <p class="text-xs font-sans font-medium text-text-tertiary uppercase tracking-wider mb-3">AI Agent Engine</p>
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-text-primary leading-tight">
        Ship AI agents in your product —{' '}
        <span class="text-brand-accent">not months of infrastructure</span>
      </h1>
      <p class="mt-4 text-base text-text-secondary font-sans leading-relaxed max-w-2xl mx-auto">
        Deploy in 5 minutes. REST API + Admin Dashboard. No backend code.
        <br />
        <span class="text-text-tertiary">Self-hosted. Any LLM. Free forever.</span>
      </p>
      <div class="mt-5 flex items-center justify-center gap-3 flex-wrap">
        <a
          href="/download"
          class="rounded-[2px] bg-brand-accent px-6 py-3 text-sm font-medium text-white hover:bg-brand-accent-hover transition-colors"
        >
          Get Started Free &rarr;
        </a>
        <a
          href="/pricing"
          class="rounded-[2px] border border-border px-6 py-3 text-sm font-medium text-text-secondary hover:border-border-hover hover:text-text-primary transition-colors"
        >
          View Pricing &rarr;
        </a>
      </div>
      <a href="/docs/getting-started/quick-start/" class="text-sm text-text-tertiary hover:text-text-secondary transition-colors">5-minute Quick Start &rarr;</a>
      <a href="/examples" class="text-sm text-brand-accent hover:underline transition-colors ml-4">Try a live agent &rarr;</a>
    </div>

    <div class="max-w-5xl mx-auto">
      <HeroDemo client:visible />
      <p class="text-center text-xs font-sans text-text-tertiary mt-3">
        Live demo: an AI agent analyzing enterprise churn — tool calls, sub-agent delegation, and real-time streaming
      </p>
    </div>
  </section>

  <!-- Works with bar -->
  <div class="py-6 px-4 border-t border-border bg-surface">
    <div class="max-w-4xl mx-auto flex flex-wrap items-center justify-center gap-x-8 gap-y-2">
      <span class="text-xs font-sans text-text-tertiary">Works with</span>
      <span class="text-sm font-semibold text-text-secondary">OpenAI</span>
      <span class="text-sm font-semibold text-text-secondary">Anthropic</span>
      <span class="text-sm font-semibold text-text-secondary">Google AI</span>
      <span class="text-sm font-semibold text-text-secondary">Ollama</span>
      <span class="text-sm font-semibold text-text-secondary">PostgreSQL</span>
      <span class="text-sm font-semibold text-text-secondary">Docker</span>
    </div>
  </div>

  <!-- ================================================================ -->
  <!-- 2. Problem Statement                                              -->
  <!-- ================================================================ -->
  <section class="py-28 px-4 border-t border-border bg-surface-alt">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold tracking-tight text-center text-text-primary mb-4">
        You want AI in your product. Not a 3-month infrastructure project.
      </h2>
      <p class="text-center text-text-secondary font-sans mb-14 max-w-2xl mx-auto">
        Sound familiar?
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Without ByteBrew -->
        <div class="rounded-[2px] border border-border bg-surface p-6 transition-all duration-200 hover:border-border-hover hover:-translate-y-0.5">
          <div class="w-12 h-12 rounded-[2px] bg-brand-accent/10 flex items-center justify-center mb-4">
            <svg class="h-6 w-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-text-primary">Without ByteBrew</h3>
          <p class="mt-3 text-sm text-text-secondary font-sans leading-relaxed">
            3-6 months building agent infrastructure. Your actual product waits.
          </p>
        </div>
        <!-- With cloud AI platforms -->
        <div class="rounded-[2px] border border-border bg-surface p-6 transition-all duration-200 hover:border-border-hover hover:-translate-y-0.5">
          <div class="w-12 h-12 rounded-[2px] bg-brand-accent/10 flex items-center justify-center mb-4">
            <svg class="h-6 w-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-text-primary">With cloud AI platforms</h3>
          <p class="mt-3 text-sm text-text-secondary font-sans leading-relaxed">
            $500-2,000/month. Your data leaves. Locked to one provider.
          </p>
        </div>
        <!-- With AI frameworks -->
        <div class="rounded-[2px] border border-border bg-surface p-6 transition-all duration-200 hover:border-border-hover hover:-translate-y-0.5">
          <div class="w-12 h-12 rounded-[2px] bg-brand-accent/10 flex items-center justify-center mb-4">
            <svg class="h-6 w-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 9.75L16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0020.25 18V6A2.25 2.25 0 0018 3.75H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-text-primary">With AI frameworks</h3>
          <p class="mt-3 text-sm text-text-secondary font-sans leading-relaxed">
            A Python library, not a product. You're still building infrastructure.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================================ -->
  <!-- 3. Solution                                                       -->
  <!-- ================================================================ -->
  <section class="py-28 px-4 border-t border-border bg-surface">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold tracking-tight text-center text-text-primary mb-4">
        One Docker container. Full AI agent runtime. Your data stays with you.
      </h2>
      <p class="text-center text-text-secondary font-sans mb-14 max-w-2xl mx-auto">
        Your server talks to ByteBrew via REST API. Agents think, call tools, stream responses back.
      </p>

      <div class="flex items-center justify-center gap-4 mt-12 mb-12 py-6 flex-wrap">
        <div class="rounded-[2px] border border-border bg-surface-alt px-8 py-4 text-center">
          <div class="text-sm text-text-tertiary">Your Server</div>
          <div class="text-base font-semibold text-text-primary mt-0.5">Next.js, FastAPI, Go</div>
        </div>
        <div class="flex flex-col items-center gap-0.5">
          <span class="text-sm text-brand-accent font-medium">REST API &rarr;</span>
          <span class="text-sm text-text-tertiary">&larr; SSE stream</span>
        </div>
        <div class="rounded-[2px] border-2 border-brand-accent shadow-md bg-surface-alt px-8 py-4 text-center">
          <div class="text-sm text-brand-accent font-medium">ByteBrew Engine</div>
          <div class="text-base font-semibold text-text-primary mt-0.5">Docker Container</div>
        </div>
        <div class="flex flex-col items-center gap-0.5">
          <span class="text-sm text-text-tertiary font-medium">&rarr;</span>
        </div>
        <div class="rounded-[2px] border border-border bg-surface-alt px-8 py-4 text-center">
          <div class="text-sm text-text-tertiary">Any LLM</div>
          <div class="text-base font-semibold text-text-primary mt-0.5">OpenAI, Gemini, Ollama</div>
        </div>
      </div>
      <p class="text-center text-xs font-sans text-text-tertiary -mt-8 mb-8">Your server handles authentication, then forwards requests to ByteBrew.</p>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
        <!-- Admin Dashboard workflow -->
        <div class="rounded-[2px] border border-border bg-surface-elevated p-6">
          <div class="text-xs font-mono text-text-tertiary uppercase tracking-wider mb-4">Admin Dashboard</div>
          <div class="space-y-3">
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 rounded-full bg-brand-accent"></div>
              <span class="text-sm font-sans text-text-primary">Create agents visually — name, model, system prompt</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 rounded-full bg-brand-accent"></div>
              <span class="text-sm font-sans text-text-primary">Enable tools — MCP servers, built-in tools, HTTP APIs</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 rounded-full bg-brand-accent"></div>
              <span class="text-sm font-sans text-text-primary">Set up multi-agent delegation — which agents can spawn which</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 rounded-full bg-brand-accent"></div>
              <span class="text-sm font-sans text-text-primary">Configure triggers — cron schedules, webhook endpoints</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 rounded-full bg-brand-accent"></div>
              <span class="text-sm font-sans text-text-primary">Manage models — add providers, test connectivity, set defaults</span>
            </div>
          </div>
          <div class="mt-4 pt-3 border-t border-border">
            <span class="text-xs font-sans text-text-tertiary">Prefer code? Export/import configuration as YAML anytime.</span>
          </div>
        </div>

        <!-- Explainer items -->
        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="mt-1">
              <svg class="shrink-0 h-5 w-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-text-primary">Agents that delegate</h4>
              <p class="mt-1 text-sm text-text-secondary font-sans leading-relaxed">Supervisor breaks tasks into sub-tasks and assigns to specialist agents.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="mt-1">
              <svg class="shrink-0 h-5 w-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-text-primary">Any tool your app needs</h4>
              <p class="mt-1 text-sm text-text-secondary font-sans leading-relaxed">Connect via MCP protocol or declare HTTP tools in the dashboard.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="mt-1">
              <svg class="shrink-0 h-5 w-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-text-primary">Agents that work on their own</h4>
              <p class="mt-1 text-sm text-text-secondary font-sans leading-relaxed">Cron schedules and webhook triggers — no user interaction needed.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="mt-1">
              <svg class="shrink-0 h-5 w-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-text-primary">Any AI model, no lock-in</h4>
              <p class="mt-1 text-sm text-text-secondary font-sans leading-relaxed">Mix different models across agents. Switch providers with one config change.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================================ -->
  <!-- 4. How It Works (3 steps)                                         -->
  <!-- ================================================================ -->
  <section class="py-24 px-4 border-t border-border bg-surface-alt">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold tracking-tight text-center text-text-primary mb-4">
        From zero to AI agent in 5 minutes
      </h2>
      <p class="text-center text-text-secondary font-sans mb-14">
        No backend code required. Configure visually or in YAML.
      </p>

      <div class="space-y-16">
        <!-- Step 1: Configure -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
          <div>
            <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-brand-accent/15 text-brand-accent text-sm font-bold">1</span>
            <h3 class="mt-3 text-xl font-semibold text-text-primary">Configure</h3>
            <p class="mt-2 text-text-secondary font-sans leading-relaxed">
              Open the Admin Dashboard and create your agent visually — pick a model, write a system prompt, enable tools. Or define everything in a YAML file if you prefer code.
            </p>
          </div>
          <div class="space-y-4">
            <!-- Admin Dashboard -->
            <div class="rounded-[2px] border border-brand-accent/30 bg-brand-accent/5 p-4">
              <p class="text-xs font-semibold text-brand-accent uppercase tracking-wider mb-2">Admin Dashboard</p>
              <p class="text-sm text-text-secondary font-sans leading-relaxed mb-3">
                Open the Admin Dashboard and create your agent visually. Set the model, system prompt, tools, and spawn rules — no YAML needed.
              </p>
              <div class="rounded-[2px] border border-border overflow-hidden">
                <img src="/screenshots/admin-agents.png" alt="Admin Dashboard — Agents list with Create Agent button" class="w-full cursor-pointer hover:opacity-80 transition-opacity lightbox-img" data-src="/screenshots/admin-agents.png" />
              </div>
            </div>

            <!-- OR separator -->
            <div class="flex items-center gap-3">
              <div class="flex-1 h-px bg-border"></div>
              <span class="text-xs text-text-tertiary uppercase tracking-wider">or</span>
              <div class="flex-1 h-px bg-border"></div>
            </div>

            <!-- YAML (secondary option) -->
            <div class="rounded-[2px] border border-border bg-surface p-4 opacity-60">
              <p class="text-xs font-semibold text-text-tertiary uppercase tracking-wider mb-2">Or use YAML</p>
              <pre class="font-mono text-sm text-text-secondary leading-relaxed overflow-x-auto"><span class="text-text-tertiary"># agents.yaml</span>
<span class="text-brand-accent">agents</span>:
  <span class="text-brand-accent">my-agent</span>:
    <span class="text-text-tertiary">model</span>: <span class="text-emerald-400">glm-5</span>
    <span class="text-text-tertiary">system</span>: <span class="text-emerald-400">"You are a helpful assistant"</span>
    <span class="text-text-tertiary">tools</span>:
      - <span class="text-emerald-400">web_search</span></pre>
            </div>
          </div>
        </div>

        <!-- Step 2: Deploy -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
          <div>
            <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-brand-accent/15 text-brand-accent text-sm font-bold">2</span>
            <h3 class="mt-3 text-xl font-semibold text-text-primary">Deploy</h3>
            <p class="mt-2 text-text-secondary font-sans leading-relaxed">
              One command. Docker Compose pulls the engine and PostgreSQL, starts everything. Your agent is live.
            </p>
          </div>
          <TerminalBlock command="docker compose up -d">
            <div class="mt-3 font-mono text-sm leading-relaxed" style="color: #DFD8D0;">
              <div style="color: #87867F;">Creating bytebrew-postgres ... done<br/>Creating bytebrew-engine  ... done</div>
              <div class="mt-3">
