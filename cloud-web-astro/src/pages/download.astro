---
import BaseLayout from '../layouts/BaseLayout.astro';
import TerminalBlock from '../components/TerminalBlock.astro';

const SHOW_EE_PRICING = import.meta.env.PUBLIC_SHOW_EE_PRICING === 'true';
---

<BaseLayout
  title="Download — ByteBrew Engine"
  description="Install ByteBrew Engine with one command. Docker Compose or standalone binary. Free forever."
>
  <div class="max-w-3xl mx-auto px-4 py-16">
    <!-- Header -->
    <h1 class="text-3xl font-bold text-text-primary text-center">Install ByteBrew Engine</h1>
    <p class="mt-3 text-center text-text-secondary text-lg">
      One command. Full AI agent runtime. Free forever.
    </p>

    <!-- Tab switcher -->
    <div class="mt-10 flex gap-2 border-b border-border">
      <button
        id="tab-docker"
        class="tab-btn px-4 py-2.5 text-sm font-medium transition-colors relative text-text-primary border-b-2 border-brand-accent cursor-pointer"
        data-tab="docker"
      >
        Docker Compose
        <span class="ml-2 inline-block text-[10px] font-semibold uppercase tracking-wide bg-green-600/20 text-green-400 border border-green-500/30 rounded-[2px] px-2 py-0.5">
          Recommended
        </span>
      </button>
      <button
        id="tab-binary"
        class="tab-btn px-4 py-2.5 text-sm font-medium transition-colors text-text-secondary hover:text-text-secondary cursor-pointer"
        data-tab="binary"
      >
        Binary
      </button>
    </div>

    <!-- Docker Compose tab -->
    <div id="panel-docker" class="tab-panel mt-8 space-y-8">
      <!-- Step 1 -->
      <div>
        <div class="flex items-center gap-3 mb-3">
          <span class="flex items-center justify-center w-7 h-7 rounded-full bg-brand-accent/20 text-brand-accent text-sm font-bold shrink-0">
            1
          </span>
          <h3 class="text-sm font-medium text-text-primary">Download configuration</h3>
        </div>
        <TerminalBlock command="curl -fsSL https://bytebrew.ai/releases/docker-compose.yml -o docker-compose.yml" />
      </div>

      <!-- Step 2 -->
      <div>
        <div class="flex items-center gap-3 mb-3">
          <span class="flex items-center justify-center w-7 h-7 rounded-full bg-brand-accent/20 text-brand-accent text-sm font-bold shrink-0">
            2
          </span>
          <h3 class="text-sm font-medium text-text-primary">Start Engine + PostgreSQL</h3>
        </div>
        <TerminalBlock command="docker compose up -d" />
      </div>

      <!-- Info box -->
      <div class="rounded-[2px] border border-border bg-surface-alt p-5 text-sm text-text-secondary">
        <p class="font-medium text-text-primary mb-1">What's included</p>
        <p>ByteBrew Engine + PostgreSQL 16. Ready in 30 seconds.</p>
      </div>

      <!-- Step 3 -->
      <div>
        <div class="flex items-center gap-3 mb-3">
          <span class="flex items-center justify-center w-7 h-7 rounded-full bg-brand-accent/20 text-brand-accent text-sm font-bold shrink-0">
            3
          </span>
          <h3 class="text-sm font-medium text-text-primary">Open admin dashboard</h3>
        </div>
        <p class="text-sm text-text-secondary">
          Open{' '}
          <code class="text-brand-accent bg-surface-alt px-1.5 py-0.5 rounded text-xs">
            http://localhost:8443/admin
          </code>{' '}
          to configure your first agent.
        </p>
      </div>

      <!-- Upgrade -->
      <div class="pt-4 border-t border-border">
        <h3 class="text-sm font-medium text-text-primary mb-3">Upgrade to latest version</h3>
        <TerminalBlock command="docker compose pull && docker compose up -d" />
      </div>
    </div>

    <!-- Binary tab -->
    <div id="panel-binary" class="tab-panel mt-8 space-y-8 hidden">
      <!-- Prerequisites -->
      <div class="rounded-[2px] border border-yellow-500/20 bg-yellow-500/5 p-5 text-sm text-text-secondary">
        <p class="font-medium text-yellow-400 mb-1">Prerequisites</p>
        <p>Requires PostgreSQL 14+ (existing instance).</p>
      </div>

      <!-- Linux/macOS -->
      <div>
        <h3 class="text-sm font-medium text-text-primary mb-3">Linux / macOS</h3>
        <TerminalBlock command="curl -fsSL https://bytebrew.ai/releases/install.sh | bash" />
      </div>

      <!-- Windows -->
      <div>
        <h3 class="text-sm font-medium text-text-primary mb-3">Windows (PowerShell)</h3>
        <TerminalBlock
          command="irm https://bytebrew.ai/releases/install.ps1 | iex"
          prefix=">"
        />
      </div>

      <!-- After install -->
      <div>
        <h3 class="text-sm font-medium text-text-primary mb-3">After install</h3>
        <div class="bg-surface border border-border rounded-[2px] p-5 font-mono text-sm text-text-secondary space-y-1 overflow-x-auto">
          <p>
            <span class="text-text-tertiary">1.</span>{' '}
            <span class="text-text-secondary">Set database:</span>{' '}
            <span class="text-green-400">export DATABASE_URL="postgresql://user:pass@host:5432/bytebrew"</span>
          </p>
          <p>
            <span class="text-text-tertiary">2.</span>{' '}
            <span class="text-text-secondary">Set model key:</span>{' '}
            <span class="text-green-400">export LLM_API_KEY=sk-...</span>
          </p>
          <p>
            <span class="text-text-tertiary">3.</span>{' '}
            <span class="text-text-secondary">Start:</span>{' '}
            <span class="text-green-400">bytebrew-engine start</span>
          </p>
          <p>
            <span class="text-text-tertiary">4.</span>{' '}
            <span class="text-text-secondary">Open admin:</span>{' '}
            <span class="text-green-400">http://localhost:8443/admin</span>
          </p>
        </div>
      </div>

      <!-- Note -->
      <p class="text-sm text-text-tertiary">
        Engine automatically creates all tables on first startup. No manual SQL needed.
      </p>
    </div>

    <!-- System Requirements -->
    <div class="mt-16">
      <h2 class="text-lg font-semibold text-text-primary mb-4">System Requirements</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
          <thead>
            <tr class="border-b border-border">
              <th class="py-3 pr-4 font-medium text-text-secondary">Resource</th>
              <th class="py-3 pr-4 font-medium text-text-secondary">Docker Compose</th>
              <th class="py-3 font-medium text-text-secondary">Binary</th>
            </tr>
          </thead>
          <tbody class="text-text-secondary">
            <tr class="border-b border-border">
              <td class="py-3 pr-4 text-text-primary">Docker</td>
              <td class="py-3 pr-4">20.10+</td>
              <td class="py-3">Not needed</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3 pr-4 text-text-primary">CPU</td>
              <td class="py-3 pr-4">1 core (2+ recommended)</td>
              <td class="py-3">Same</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3 pr-4 text-text-primary">RAM</td>
              <td class="py-3 pr-4">1 GB (2 GB+ recommended)</td>
              <td class="py-3">512 MB + your PG</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3 pr-4 text-text-primary">Disk</td>
              <td class="py-3 pr-4">500 MB + data</td>
              <td class="py-3">100 MB + your PG</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3 pr-4 text-text-primary">PostgreSQL</td>
              <td class="py-3 pr-4">Included</td>
              <td class="py-3">14+ (bring your own)</td>
            </tr>
            <tr>
              <td class="py-3 pr-4 text-text-primary">Network</td>
              <td class="py-3 pr-4">Outbound to LLM provider</td>
              <td class="py-3">Same</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Bottom links -->
    <div class="mt-12 flex flex-wrap gap-4">
      <span class="text-sm text-text-tertiary cursor-not-allowed">
        Your First Agent in 5 Minutes
      </span>
      <span class="text-sm text-text-tertiary cursor-not-allowed">
        Configuration Reference
      </span>
      <span class="text-sm text-text-tertiary cursor-not-allowed">
        API Reference
      </span>
    </div>

    <!-- EE upgrade section -->
    {SHOW_EE_PRICING && (
      <div class="mt-16 pt-8 border-t border-border">
        <h2 class="text-lg font-semibold text-text-primary mb-4">Upgrade to Enterprise Edition</h2>
        <div class="bg-surface border border-border rounded-[2px] p-5 font-mono text-sm text-text-secondary space-y-1 overflow-x-auto">
          <p>
            <span class="text-text-tertiary">1.</span>{' '}
            Subscribe at{' '}
            <span class="text-brand-accent">bytebrew.ai/pricing</span>
          </p>
          <p>
            <span class="text-text-tertiary">2.</span>{' '}
            Download <span class="text-green-400">license.jwt</span> from your dashboard
          </p>
          <p>
            <span class="text-text-tertiary">3.</span>{' '}
            Place in <span class="text-green-400">~/.bytebrew/license.jwt</span>
          </p>
          <p>
            <span class="text-text-tertiary">4.</span>{' '}
            Restart Engine — observability and compliance features are now active
          </p>
        </div>
      </div>
    )}
  </div>

  <!-- Tab switching script -->
  <script is:inline>
    (function() {
      function initTabs() {
        var tabButtons = document.querySelectorAll('.tab-btn');
        var tabPanels = document.querySelectorAll('.tab-panel');

        tabButtons.forEach(function(btn) {
          if (btn.dataset.initialized) return;
          btn.dataset.initialized = 'true';

          btn.addEventListener('click', function() {
            var tab = btn.dataset.tab;
            if (!tab) return;

            tabButtons.forEach(function(b) {
              if (b.dataset.tab === tab) {
                b.classList.remove('text-text-secondary');
                b.classList.add('text-text-primary', 'border-b-2', 'border-brand-accent');
              } else {
                b.classList.add('text-text-secondary');
                b.classList.remove('text-text-primary', 'border-b-2', 'border-brand-accent');
              }
            });

            tabPanels.forEach(function(panel) {
              if (panel.id === 'panel-' + tab) {
                panel.classList.remove('hidden');
              } else {
                panel.classList.add('hidden');
              }
            });
          });
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initTabs);
      } else {
        initTabs();
      }
    })();
  </script>
</BaseLayout>
