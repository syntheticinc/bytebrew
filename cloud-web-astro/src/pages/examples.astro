---
import BaseLayout from '../layouts/BaseLayout.astro';
import { EXAMPLES } from '../data/examples';
---

<BaseLayout
  title="Examples — ByteBrew Engine"
  description="See ByteBrew Engine in action. Each demo is a fully working agent you can try live and run yourself."
>
  <div>
    {/* Header */}
    <section class="py-16 px-4 text-center">
      <h1 class="text-4xl font-bold tracking-tight text-text-primary">
        Examples
      </h1>
      <p class="mt-4 text-text-secondary max-w-xl mx-auto">
        See ByteBrew Engine in action. Each demo is a fully working agent you can try live and run yourself.
      </p>
    </section>

    {/* Cards grid */}
    <section class="px-4 pb-20">
      <div class="max-w-5xl mx-auto grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {EXAMPLES.map((example) => (
          <a
            href={`/examples/${example.slug}`}
            class="group rounded-[2px] border border-border bg-surface-alt p-6 flex flex-col gap-4 hover:border-brand-accent/30 transition-colors"
          >
            {/* Icon + title */}
            <div class="flex items-center gap-3">
              <span class="text-3xl" role="img" aria-label={example.title}>
                {example.icon}
              </span>
              <div>
                <h2 class="text-lg font-bold text-text-primary group-hover:text-brand-accent transition-colors">
                  {example.title}
                </h2>
                <p class="text-sm text-text-secondary mt-0.5">{example.subtitle}</p>
              </div>
            </div>

            {/* Feature tags */}
            <div class="flex flex-wrap gap-1.5">
              {example.features.map((feature) => (
                <span
                  class="rounded-[2px] border border-border px-2.5 py-0.5 text-[11px] text-text-secondary"
                >
                  {feature}
                </span>
              ))}
            </div>

            {/* CTA */}
            <div class="mt-auto pt-2">
              <span class="inline-flex items-center gap-1 text-sm font-medium text-brand-accent group-hover:gap-2 transition-all">
                Try Demo
                <svg
                  class="h-4 w-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
                  />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
