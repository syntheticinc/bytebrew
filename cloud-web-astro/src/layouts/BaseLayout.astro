---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'ByteBrew Engine — Self-hosted AI Agent Runtime',
  description = 'Add an AI agent to your product in one day. Self-hosted, any LLM, free forever. Multi-agent orchestration, tool calling, SSE streaming, REST API.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="ByteBrew Engine" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="canonical" href={Astro.url.href} />

    <!-- Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Theme init (prevent flash) -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem('bytebrew-theme');
        if (!t || t === 'system') {
          t = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        }
        if (t === 'light') document.documentElement.classList.add('light');
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface text-text-primary font-mono">
    <!-- Navigation -->
    <nav class="border-b border-border bg-surface/80 backdrop-blur-sm sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-14">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-2">
            <img src="/logo-dark.svg" alt="ByteBrew" class="h-8 logo-dark" />
            <img src="/logo-light.png" alt="ByteBrew" class="h-8 logo-light" />
          </a>

          <!-- Desktop nav -->
          <div class="hidden md:flex items-center gap-4">
            <a href="/docs" class="text-sm text-text-secondary hover:text-text-primary transition-colors">Docs</a>
            <a href="/examples" class="text-sm text-text-secondary hover:text-text-primary transition-colors">Examples</a>
            <a href="/pricing" class="text-sm text-text-secondary hover:text-text-primary transition-colors">Pricing</a>
            <a href="/download" class="text-sm text-text-secondary hover:text-text-primary transition-colors">Download</a>
            <button
              id="theme-toggle"
              class="cursor-pointer text-text-secondary opacity-60 hover:opacity-100 transition-opacity p-1"
              aria-label="Toggle theme"
            >
              <!-- Sun (dark mode) -->
              <svg id="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden">
                <circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" /><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" /><line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" /><line x1="4.22" y1="19.78" x2="5.64" y2="18.36" /><line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
              </svg>
              <!-- Moon (light mode) -->
              <svg id="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
              </svg>
            </button>
            <a
              href="/download"
              class="rounded-[2px] bg-brand-accent px-4 py-1.5 text-sm font-medium text-white hover:bg-brand-accent-hover transition-colors"
            >
              Get Started
            </a>
          </div>

          <!-- Mobile hamburger -->
          <button
            id="mobile-menu-btn"
            class="md:hidden text-text-secondary hover:text-text-primary transition-colors"
            aria-label="Toggle menu"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>

        <!-- Mobile menu -->
        <div id="mobile-menu" class="md:hidden border-t border-border py-3 flex-col gap-2 hidden">
          <a href="/docs" class="block text-sm text-text-secondary hover:text-text-primary transition-colors py-1">Docs</a>
          <a href="/examples" class="block text-sm text-text-secondary hover:text-text-primary transition-colors py-1">Examples</a>
          <a href="/pricing" class="block text-sm text-text-secondary hover:text-text-primary transition-colors py-1">Pricing</a>
          <a href="/download" class="block text-sm text-text-secondary hover:text-text-primary transition-colors py-1">Download</a>
          <a href="/download" class="mt-1 inline-block rounded-[2px] bg-brand-accent px-4 py-1.5 text-sm font-medium text-white hover:bg-brand-accent-hover transition-colors">
            Get Started
          </a>
        </div>
      </div>
    </nav>

    <!-- Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-border py-6">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row items-center justify-center gap-3 text-xs text-text-tertiary">
        <span>ByteBrew Engine &mdash; Open infrastructure for AI agents</span>
        <span class="hidden sm:inline">&middot;</span>
        <div class="flex items-center gap-3">
          <a href="/privacy" class="hover:text-text-secondary transition-colors">Privacy Policy</a>
          <span>&middot;</span>
          <a href="/terms" class="hover:text-text-secondary transition-colors">Terms of Service</a>
        </div>
        <span class="hidden sm:inline">&middot;</span>
        <a href="https://github.com/syntheticinc/bytebrew" target="_blank" rel="noopener noreferrer" class="text-text-tertiary hover:text-text-primary transition-colors" title="GitHub">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        </a>
        <span class="hidden sm:inline">&middot;</span>
        <a href="https://github.com/syntheticinc/bytebrew-examples" target="_blank" rel="noopener noreferrer" class="text-text-tertiary hover:text-text-primary transition-colors text-xs">
          Examples on GitHub
        </a>
        <span class="hidden sm:inline">&middot;</span>
        <span>&copy; 2026 ByteBrew</span>
      </div>
    </footer>

    <!-- Theme toggle + mobile menu scripts -->
    <script is:inline>
      (function() {
        // Theme
        var toggle = document.getElementById('theme-toggle');
        var sunIcon = document.getElementById('icon-sun');
        var moonIcon = document.getElementById('icon-moon');

        function updateIcons() {
          var isLight = document.documentElement.classList.contains('light');
          if (sunIcon) sunIcon.style.display = isLight ? 'none' : 'block';
          if (moonIcon) moonIcon.style.display = isLight ? 'block' : 'none';
        }
        updateIcons();

        if (toggle) {
          toggle.addEventListener('click', function() {
            var isLight = document.documentElement.classList.toggle('light');
            localStorage.setItem('bytebrew-theme', isLight ? 'light' : 'dark');
            localStorage.setItem('starlight-theme', isLight ? 'light' : 'dark');
            updateIcons();
          });
        }

        // Mobile menu
        var btn = document.getElementById('mobile-menu-btn');
        var menu = document.getElementById('mobile-menu');
        if (btn && menu) {
          btn.addEventListener('click', function() {
            menu.classList.toggle('hidden');
            menu.classList.toggle('flex');
          });
        }
      })();
    </script>
  </body>
</html>
