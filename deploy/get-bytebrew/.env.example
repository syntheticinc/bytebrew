# ByteBrew Engine Configuration
# Copy to .env and edit before running docker compose up

# LLM Provider API Key (required for AI agent functionality)
LLM_API_KEY=sk-your-key-here

# Admin Dashboard Credentials
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# PostgreSQL Password (optional, default: bytebrew)
POSTGRES_PASSWORD=bytebrew

# Engine Port (optional, default: 8443)
ENGINE_PORT=8443
