bytebrew.ai, www.bytebrew.ai {
    handle /releases/* {
        root * /var/www
        file_server browse
    }

    @docs path /docs /docs/*
    handle @docs {
        root * /var/www/bytebrew-docs
        try_files {path} {path}/index.html {path}.html /docs/index.html
        @hashedAssets path /docs/_astro/*
        header @hashedAssets Cache-Control "public, max-age=31536000, immutable"
        @notAssets not path /docs/_astro/*
        header @notAssets Cache-Control "no-cache"
        file_server
    }

    # Cloud API proxy (same-origin for SPA)
    handle /api/* {
        reverse_proxy 127.0.0.1:8080
    }

    # Demo web-client
    handle /demo/api/* {
        uri strip_prefix /demo
        reverse_proxy 127.0.0.1:3000
    }
    handle /demo/* {
        uri strip_prefix /demo
        reverse_proxy 127.0.0.1:3000
    }

    # Example demo API proxies
    handle /examples/hr-assistant/api/* {
        uri strip_prefix /examples/hr-assistant
        reverse_proxy 127.0.0.1:3001
    }
    handle /examples/support-agent/api/* {
        uri strip_prefix /examples/support-agent
        reverse_proxy 127.0.0.1:3002
    }
    handle /examples/sales-agent/api/* {
        uri strip_prefix /examples/sales-agent
        reverse_proxy 127.0.0.1:3003
    }

    # React SPA assets (JS/CSS bundles from Vite build)
    handle /assets/* {
        root * /var/www/bytebrew-cloud-web-spa
        header Cache-Control "public, max-age=31536000, immutable"
        file_server
    }

    # React SPA for auth-gated pages (dashboard, login, register, billing, settings, team, example demos)
    @reactApp path /dashboard /dashboard/* /login /register /forgot-password /reset-password /verify-email /billing /billing/* /settings /team /examples/*
    handle @reactApp {
        root * /var/www/bytebrew-cloud-web-spa
        try_files {path} /index.html
        header Cache-Control "no-cache"
        file_server
    }

    # Astro static site for public pages (landing, pricing, download, examples index, terms, privacy)
    handle {
        root * /var/www/bytebrew-cloud-web
        try_files {path} {path}/index.html /index.html
        @astroAssets path /_astro/*
        header @astroAssets Cache-Control "public, max-age=31536000, immutable"
        header Cache-Control "no-cache"
        file_server
    }

    encode gzip
}

app.bytebrew.ai {
    redir https://bytebrew.ai{uri}
}

api.bytebrew.ai {
    reverse_proxy 127.0.0.1:8080
}

bridge.bytebrew.ai {
    reverse_proxy h2c://127.0.0.1:8443
}

mcp.bytebrew.ai {
    reverse_proxy 127.0.0.1:8090
}
