{
    acme_ca https://acme-v02.api.letsencrypt.org/directory
}

bytebrew.ai, www.bytebrew.ai {
    handle /releases/* {
        root * /var/www
        file_server browse
    }

    @docs path /docs /docs/*
    handle @docs {
        root * /var/www/bytebrew-docs
        try_files {path} {path}/index.html {path}.html /docs/index.html

        # Hashed assets — cache forever (immutable)
        @hashedAssets {
            path /docs/_astro/*
        }
        header @hashedAssets Cache-Control "public, max-age=31536000, immutable"

        # Everything else — always revalidate
        @notAssets {
            not path /docs/_astro/*
        }
        header @notAssets Cache-Control "no-cache"

        file_server
    }

    # Example demo API proxies
    handle /examples/hr-assistant/api/* {
        uri strip_prefix /examples/hr-assistant
        reverse_proxy 127.0.0.1:3001
    }

    handle /examples/support-agent/api/* {
        uri strip_prefix /examples/support-agent
        reverse_proxy 127.0.0.1:3002
    }

    handle /examples/sales-agent/api/* {
        uri strip_prefix /examples/sales-agent
        reverse_proxy 127.0.0.1:3003
    }

    handle {
        root * /var/www/bytebrew-cloud-web
        try_files {path} /index.html

        # Hashed assets — cache forever
        @webAssets path /assets/*
        header @webAssets Cache-Control "public, max-age=31536000, immutable"

        # HTML — revalidate
        header Cache-Control "no-cache"

        file_server
    }

    encode gzip
}

app.bytebrew.ai {
    redir https://bytebrew.ai{uri}
}

api.bytebrew.ai {
    reverse_proxy 127.0.0.1:8080
}

bridge.bytebrew.ai {
    reverse_proxy h2c://127.0.0.1:8443
}

code.bytebrew.ai {
    redir https://bytebrew.ai{uri}
}

get.bytebrew.ai {
    root * /var/www/releases
    file_server browse
    encode gzip
}

docs.bytebrew.ai {
    root * /var/www/docs-bytebrew
    try_files {path} {path}/index.html {path}.html /404.html
    file_server
    encode gzip
}
