{
    acme_ca https://acme-v02.api.letsencrypt.org/directory
}

bytebrew.ai, www.bytebrew.ai {
    handle /releases/* {
        root * /var/www
        file_server browse
    }

    handle {
        root * /var/www/bytebrew-cloud-web
        try_files {path} /index.html
        file_server
    }

    encode gzip
}

app.bytebrew.ai {
    redir https://bytebrew.ai{uri}
}

api.bytebrew.ai {
    reverse_proxy 127.0.0.1:8080
}

bridge.bytebrew.ai {
    reverse_proxy h2c://127.0.0.1:8443
}
